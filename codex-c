      "API 和模型管理" \
      "提示词 (Prompt) 管理" \
      "MCP (上下文协议) 管理" \
      "Skill (技能/工具) 管理" \
      "重启/重载 Codex 服务" \
      "退出脚本")"
      if [ -z "$choice" ]; then
        continue
      fi
    else
      if [ -n "$C_CYAN" ]; then
        printf "[ %s%d%s ] %s\n" "$C_BOLD$C_MAGENTA" 1 "$C_RESET" "API 和模型管理"
        printf "[ %s%d%s ] %s\n" "$C_BOLD$C_MAGENTA" 2 "$C_RESET" "提示词 (Prompt) 管理"
        printf "[ %s%d%s ] %s\n" "$C_BOLD$C_MAGENTA" 3 "$C_RESET" "MCP (上下文协议) 管理"
        printf "[ %s%d%s ] %s\n" "$C_BOLD$C_MAGENTA" 4 "$C_RESET" "Skill (技能/工具) 管理"
        printf "[ %s%d%s ] %s\n" "$C_BOLD$C_MAGENTA" 5 "$C_RESET" "重启/重载 Codex 服务"
        printf "[ %s%d%s ] %s\n" "$C_BOLD$C_MAGENTA" 0 "$C_RESET" "退出脚本"
      else
        printf "[ %d ] %s\n" 1 "API 和模型管理"
        printf "[ %d ] %s\n" 2 "提示词 (Prompt) 管理"
        printf "[ %d ] %s\n" 3 "MCP (上下文协议) 管理"
        printf "[ %d ] %s\n" 4 "Skill (技能/工具) 管理"
        printf "[ %d ] %s\n" 5 "重启/重载 Codex 服务"
        printf "[ %d ] %s\n" 0 "退出脚本"
      fi
      echo
      read -r -p "codex-core $(prompt_symbol) 请输入对应数字选择 [0-5]: " choice
      if [ -z "$choice" ]; then
        continue
      fi
    fi
    case "$choice" in
      1) api_menu ;;
      2) prompt_menu ;;
      3) mcp_menu ;;
      4) skill_menu ;;
      5) service_menu ;;
      0) echo "退出脚本。"; exit 0 ;;
      *) echo "无效选择。" ;;
    esac
  done
}

main
