normalize_api_url() {
  local url="$1"
  url="${url%/}"
  echo "$url"
}

detect_provider() {
  local url="$1"
  local lower
  lower="$(echo "$url" | tr '[:upper:]' '[:lower:]')"
  if [[ "$lower" == *"openai"* ]]; then
    echo "openai"
  elif [[ "$lower" == *"anthropic"* ]]; then
    echo "anthropic"
  else
    echo "unknown"
  fi
}

validate_connectivity() {
  local url="$1"
  if [ -z "$url" ]; then
    echo "未设置 API 地址，无法校验。"
    return 0
  fi
  if ! command -v curl >/dev/null 2>&1; then
    echo "未检测到 curl，跳过连通性校验。"
    return 0
  fi
  local code
  code="$(curl -sS -o /dev/null -w "%{http_code}" --connect-timeout "$CONNECT_TIMEOUT" --max-time "$CONNECT_TIMEOUT" "$url" || true)"
  if [ "$code" = "000" ]; then
    echo "连通性校验失败：无法连接到 $url"
    return 1
  fi
  echo "连通性校验通过（HTTP $code）。"
  return 0
}

validate_openai_model() {
  local api_url="$1"
  local token="$2"
  local model="$3"
  if [ -z "$token" ]; then
    echo "未设置 Token，跳过模型可用性校验。"
    return 0
  fi
  if ! command -v curl >/dev/null 2>&1; then
    echo "未检测到 curl，跳过模型可用性校验。"
    return 0
  fi
  if ! command -v jq >/dev/null 2>&1; then
    echo "未检测到 jq，跳过模型可用性校验。"
    return 0
  fi

  local base endpoint tmp code
  base="$(normalize_api_url "$api_url")"
  endpoint="${base}/models"
  tmp="$(mktemp)"
  code="$(curl -sS -H "Authorization: Bearer $token" -o "$tmp" -w "%{http_code}" \
    --connect-timeout "$CONNECT_TIMEOUT" --max-time "$CONNECT_TIMEOUT" "$endpoint" || true)"
  if [ "$code" = "000" ]; then
    echo "模型校验失败：无法连接到 $endpoint"
    rm -f "$tmp"
    return 1
  fi
  if [ "$code" -ge 400 ]; then
    echo "模型校验失败（HTTP $code），可能是 Token 无效或接口受限。"
    rm -f "$tmp"
    return 1
  fi
  if jq -e --arg m "$model" '.data[]?.id == $m' "$tmp" >/dev/null 2>&1; then
    echo "模型校验通过：$model"
  else
    echo "模型未在可用列表中找到：$model"
  fi
  rm -f "$tmp"
  return 0
}

validate_anthropic_model() {
  local api_url="$1"
  local token="$2"
  local model="$3"
  if [ -z "$token" ]; then
    echo "未设置 Token，跳过模型可用性校验。"
    return 0
  fi
  if ! command -v curl >/dev/null 2>&1; then
    echo "未检测到 curl，跳过模型可用性校验。"
    return 0
  fi
  if ! command -v jq >/dev/null 2>&1; then
    echo "未检测到 jq，跳过模型可用性校验。"
    return 0
  fi

  local base endpoint tmp code
  base="$(normalize_api_url "$api_url")"
  if [[ "$base" == */v1 ]]; then
    endpoint="${base}/models"
  else
    endpoint="${base}/v1/models"
  fi
  tmp="$(mktemp)"
  code="$(curl -sS -H "x-api-key: $token" -H "anthropic-version: 2023-06-01" \
    -o "$tmp" -w "%{http_code}" --connect-timeout "$CONNECT_TIMEOUT" \
    --max-time "$CONNECT_TIMEOUT" "$endpoint" || true)"
  if [ "$code" = "000" ]; then
    echo "模型校验失败：无法连接到 $endpoint"
    rm -f "$tmp"
    return 1
  fi
  if [ "$code" -ge 400 ]; then
    echo "模型校验失败（HTTP $code），接口可能不支持或 Token 无效。"
    rm -f "$tmp"
    return 1
  fi
  if jq -e --arg m "$model" '.data[]?.id == $m' "$tmp" >/dev/null 2>&1; then
    echo "模型校验通过：$model"
  else
    echo "模型未在可用列表中找到：$model"
  fi
  rm -f "$tmp"
  return 0
}

validate_api_model() {
  if [ "$ENABLE_VALIDATE" != "1" ]; then
    return 0
  fi
  ensure_config || return 0
  if [ "$CONFIG_FORMAT" = "json" ]; then
    require_jq || return 0
  fi
  sync_paths

  local api_url model token provider
  api_url="$(get_config_value "$API_URL_PATH")"
  model="$(get_config_value "$MODEL_PATH")"
  token="$(get_config_value "$API_TOKEN_PATH")"
  if [ -z "$token" ] && [ -f "$AUTH_PATH" ] && command -v jq >/dev/null 2>&1; then
    local auth_key
    provider="$(detect_provider "$api_url")"
    if [ "$provider" = "anthropic" ]; then
      auth_key="ANTHROPIC_API_KEY"
    else
      auth_key="OPENAI_API_KEY"
    fi
    token="$(jq -r --arg k "$auth_key" '.[$k] // empty' "$AUTH_PATH" 2>/dev/null)"
  fi
  provider="$(detect_provider "$api_url")"

  echo "开始校验 API 连通性与模型可用性..."
  validate_connectivity "$api_url" || return 1

  if [ "$MODEL_CHECK" != "1" ]; then
    echo "模型校验已关闭。"
    return 0
  fi

  case "$provider" in
    openai) validate_openai_model "$api_url" "$token" "$model" ;;
    anthropic) validate_anthropic_model "$api_url" "$token" "$model" ;;
    *)
      echo "未识别服务商，仅做连通性校验。"
      ;;
  esac
}

json_type() {
  local path="$1"
  jq -r "($path | type) // \"null\"" "$CONFIG_PATH" 2>/dev/null
}

resolve_path() {
  local var_name="$1"
  local current_path="$2"
  shift 2
  local candidates=("$@")
  if config_exists "$current_path"; then
    return 0
  fi

  local cand
  for cand in "${candidates[@]}"; do
    if config_exists "$cand"; then
      printf -v "$var_name" '%s' "$cand"
      AUTO_PATH_NOTES+=( "$current_path -> $cand" )
      return 0
    fi
  done
}

sync_paths() {
  AUTO_PATH_NOTES=()
  if [ "$CONFIG_FORMAT" = "toml" ]; then
    local provider
    provider="$(get_toml_value "$TOML_PROVIDER_PATH")"
    MODEL_PATH="$TOML_MODEL_PATH"
    PROMPT_PATH="$TOML_PROMPT_PATH"
    if [ -n "$provider" ]; then
      API_URL_PATH=".model_providers.${provider}.base_url"
    fi
  else
    resolve_path API_URL_PATH "$API_URL_PATH" "${API_URL_CANDIDATES[@]}"
    resolve_path API_TOKEN_PATH "$API_TOKEN_PATH" "${API_TOKEN_CANDIDATES[@]}"
    resolve_path MODEL_PATH "$MODEL_PATH" "${MODEL_CANDIDATES[@]}"
    resolve_path PROMPT_PATH "$PROMPT_PATH" "${PROMPT_CANDIDATES[@]}"
    resolve_path MCP_PATH "$MCP_PATH" "${MCP_CANDIDATES[@]}"
    resolve_path SKILL_PATH "$SKILL_PATH" "${SKILL_CANDIDATES[@]}"
  fi
}

count_json_path() {
  local path="$1"
  jq -r "def count(v):
    if v == null then 0
    elif (v|type) == \"array\" then (v|length)
    elif (v|type) == \"object\" then (v|keys|length)
    else 1 end;
    count($path)
  " "$CONFIG_PATH" 2>/dev/null
}

count_config_path() {
  local path="$1"
  if [ "$CONFIG_FORMAT" = "toml" ]; then
    local value
    value="$(get_toml_value "$path")"
    if [ -z "$value" ]; then
      echo "0"
    else
      if python3 - <<'PY' "$value" >/dev/null 2>&1
import sys, json
v = json.loads(sys.argv[1])
if isinstance(v, list):
    print(len(v))
elif isinstance(v, dict):
    print(len(v.keys()))
else:
    print(1)
PY
      then
        python3 - <<'PY' "$value"
import sys, json
v = json.loads(sys.argv[1])
if isinstance(v, list):
    print(len(v))
elif isinstance(v, dict):
    print(len(v.keys()))
else:
    print(1)
PY
      else
        echo "1"
      fi
    fi
  else
    count_json_path "$path"
  fi
}

get_status() {
  if [ -n "$SERVICE_NAME" ] && pgrep -f "$SERVICE_NAME" >/dev/null 2>&1; then
    if [ -n "$C_GREEN" ]; then
      printf "%s[运行中]%s\n" "$C_GREEN" "$C_RESET"
    else
      echo "[运行中]"
    fi
  else
    if [ -n "$C_YELLOW" ]; then
      printf "%s[未启动]%s\n" "$C_YELLOW" "$C_RESET"
    else
      echo "[未启动]"
    fi
  fi
}

get_version() {
  if [ -n "$CODEX_BIN" ] && command -v "$CODEX_BIN" >/dev/null 2>&1; then
    "$CODEX_BIN" --version 2>/dev/null | head -n 1
  else
    echo ""
  fi
}

