          if [[ "$ans" =~ ^[Yy]$ ]]; then
            backup_config
            toml_mcp_remove_any_block "$name"
            echo "已删除：$name"
          else
            echo "已取消。"
          fi
        else
          collection_remove "MCP" "$MCP_PATH"
        fi
        pause
        ;;
      6)
        ensure_config || { pause; continue; }
        if [ "$CONFIG_FORMAT" = "toml" ]; then
          mapfile -t names < <(toml_mcp_list_names)
          if [ "${#names[@]}" -eq 0 ]; then
            echo "暂无可禁用的 MCP。"
            pause
            continue
          fi
          echo "请选择要禁用的 MCP："
          local i=1 sel
          for sel in "${names[@]}"; do
            echo "${i}. ${sel}"
            i=$((i + 1))
          done
          read -r -p "输入序号（留空取消）: " idx
          if [ -z "$idx" ]; then
            echo "已取消。"
            pause
            continue
          fi
          if ! [[ "$idx" =~ ^[0-9]+$ ]] || [ "$idx" -lt 1 ] || [ "$idx" -gt "${#names[@]}" ]; then
            echo "无效序号。"
            pause
            continue
          fi
          local name
          name="${names[$((idx - 1))]}"
          backup_config
          toml_mcp_disable_name "$name"
          echo "已禁用：$name"
        else
          echo "JSON 配置暂不支持禁用 MCP。"
        fi
        pause
        ;;
      7)
        ensure_config || { pause; continue; }
        if [ "$CONFIG_FORMAT" = "toml" ]; then
          mapfile -t names < <(toml_mcp_list_disabled_names)
          if [ "${#names[@]}" -eq 0 ]; then
            echo "暂无可启用的 MCP。"
            pause
            continue
          fi
          echo "请选择要启用的 MCP："
          local i=1 sel
          for sel in "${names[@]}"; do
            echo "${i}. ${sel}"
            i=$((i + 1))
          done
          read -r -p "输入序号（留空取消）: " idx
          if [ -z "$idx" ]; then
            echo "已取消。"
            pause
            continue
          fi
          if ! [[ "$idx" =~ ^[0-9]+$ ]] || [ "$idx" -lt 1 ] || [ "$idx" -gt "${#names[@]}" ]; then
            echo "无效序号。"
            pause
            continue
          fi
          local name
          name="${names[$((idx - 1))]}"
          backup_config
          toml_mcp_enable_name "$name"
          echo "已启用：$name"
        else
          echo "JSON 配置暂不支持启用 MCP。"
        fi
        pause
        ;;
      8)
        ensure_config || { pause; continue; }
        if [ "$CONFIG_FORMAT" = "toml" ]; then
          read -r -p "确认禁用全部 MCP？[y/N] " ans
          if [[ "$ans" =~ ^[Yy]$ ]]; then
            backup_config
            toml_mcp_disable_all
            echo "已禁用全部 MCP。"
          else
            echo "已取消。"
          fi
        else
          echo "JSON 配置暂不支持禁用 MCP。"
        fi
        pause
        ;;
      9)
        ensure_config || { pause; continue; }
        if [ "$CONFIG_FORMAT" = "toml" ]; then
          read -r -p "确认启用全部 MCP？[y/N] " ans
          if [[ "$ans" =~ ^[Yy]$ ]]; then
            backup_config
            toml_mcp_enable_all
            echo "已启用全部 MCP。"
          else
            echo "已取消。"
          fi
        else
          echo "JSON 配置暂不支持启用 MCP。"
        fi
        pause
        ;;
      0)
        return
        ;;
      *)
        echo "无效选择。"
        ;;
    esac
  done
}
skill_menu() {
  while true; do
    echo
    local choice
    choice="$(menu_choose "Skill (技能/工具) 管理" \
      "列出 Skill 目录" \
      "查看 SKILL.md" \
      "新建 Skill" \
      "删除 Skill" \
      "Vim 深度编辑" \
      "返回主菜单")"
    if [ -z "$choice" ]; then
      return
    fi
    case "$choice" in
      1)
        sync_codex_dirs
        ensure_dir "$SKILLS_DIR" "Skills" || { pause; continue; }
        echo "Skill 目录列表:"
        for d in "$SKILLS_DIR"/*; do
          [ -d "$d" ] && basename "$d"
        done
        if ! ls -1 "$SKILLS_DIR"/*/ >/dev/null 2>&1; then
          echo "暂无 Skill 目录。"
        fi
        pause
        ;;
      2)
        sync_codex_dirs
        ensure_dir "$SKILLS_DIR" "Skills" || { pause; continue; }
        read -r -p "请输入要查看的 Skill 名称（留空取消）: " name
        if [ -z "$name" ]; then
          echo "未输入，已取消。"
          pause
          continue
        fi
        local dir file
        dir="$(skill_dir_from_name "$name")"
        file="$dir/SKILL.md"
        if [ -f "$file" ]; then
          echo "SKILL.md 内容:"
          cat "$file"
        else
          echo "未找到：$file"
        fi
        pause
        ;;
      3)
        sync_codex_dirs
        ensure_dir "$SKILLS_DIR" "Skills" || { pause; continue; }
        read -r -p "请输入 Skill 名称（留空取消）: " name
        if [ -z "$name" ]; then
          echo "未输入，已取消。"
          pause
          continue
        fi
        local dir file
        dir="$(skill_dir_from_name "$name")"
        file="$dir/SKILL.md"
        if [ ! -d "$dir" ]; then
          mkdir -p "$dir" || { echo "创建失败：$dir"; pause; continue; }
        fi
        if [ -f "$file" ]; then
          echo "已存在：$file"
        else
          printf "" > "$file" || { echo "创建失败：$file"; pause; continue; }
          echo "已创建：$file"
        fi
        read -r -p "是否立即编辑？[y/N] " ans
        if [[ "$ans" =~ ^[Yy]$ ]]; then
          vim "$file"
        fi
        pause
        ;;
      4)
        sync_codex_dirs
        ensure_dir "$SKILLS_DIR" "Skills" || { pause; continue; }
        local items=()
        local d
        for d in "$SKILLS_DIR"/*; do
          [ -d "$d" ] && items+=( "$(basename "$d")" )
        done
        if [ "${#items[@]}" -eq 0 ]; then
          echo "暂无 Skill 目录。"
          pause
          continue
        fi
        echo "可删除的 Skill："
        local i=1
        local item
        for item in "${items[@]}"; do
          echo "${i}. ${item}"
          i=$((i + 1))
        done
        read -r -p "输入序号（留空取消）: " idx
        if [ -z "$idx" ]; then
          echo "已取消。"
          pause
          continue
        fi
        if ! [[ "$idx" =~ ^[0-9]+$ ]] || [ "$idx" -lt 1 ] || [ "$idx" -gt "${#items[@]}" ]; then
          echo "无效序号。"
          pause
          continue
        fi
        local dir
        dir="$SKILLS_DIR/${items[$((idx - 1))]}"
        if [ ! -d "$dir" ]; then
          echo "未找到：$dir"
          pause
          continue
        fi
        read -r -p "确认删除 $dir ? [y/N] " ans
        if [[ "$ans" =~ ^[Yy]$ ]]; then
          trash_move "$dir" "skill"
        else
          echo "已取消。"
        fi
        pause
        ;;
      5)
        sync_codex_dirs
        ensure_dir "$SKILLS_DIR" "Skills" || { pause; continue; }
        local items=()
        local d
        for d in "$SKILLS_DIR"/*; do
          [ -d "$d" ] && items+=( "$(basename "$d")" )
        done
        if [ "${#items[@]}" -eq 0 ]; then
          echo "暂无 Skill 目录，已取消。"
          pause
        else
          echo "可编辑的 Skill："
          local i=1 item
          for item in "${items[@]}"; do
            echo "${i}. ${item}"
            i=$((i + 1))
          done
          read -r -p "输入序号（留空取消）: " idx
          if [ -z "$idx" ]; then
            echo "已取消。"
            pause
          else
            if ! [[ "$idx" =~ ^[0-9]+$ ]] || [ "$idx" -lt 1 ] || [ "$idx" -gt "${#items[@]}" ]; then
              echo "无效序号。"
            else
              vim "$SKILLS_DIR/${items[$((idx - 1))]}/SKILL.md"
            fi
          fi
        fi
        ;;
      0)
        return
        ;;
      *)
        echo "无效选择。"
        ;;
    esac
  done
}

service_menu() {
  while true; do
    echo
    local choice
    choice="$(menu_choose "重启/重载 Codex 服务" \
      "重启服务" \
      "重载服务" \
      "查看服务状态" \
      "返回主菜单")"
    if [ -z "$choice" ]; then
      return
    fi
    case "$choice" in
      1)
        if command -v systemctl >/dev/null 2>&1; then
          read -r -p "确认重启 $SERVICE_UNIT 服务？[y/N] " ans
          if [[ "$ans" =~ ^[Yy]$ ]]; then
            sudo systemctl restart "$SERVICE_UNIT"
          fi
        else
          echo "未检测到 systemctl，无法重启服务。"
        fi
        pause
        ;;
      2)
        if command -v systemctl >/dev/null 2>&1; then
          read -r -p "确认重载 $SERVICE_UNIT 服务？[y/N] " ans
          if [[ "$ans" =~ ^[Yy]$ ]]; then
            sudo systemctl reload "$SERVICE_UNIT"
          fi
        else
          echo "未检测到 systemctl，无法重载服务。"
        fi
        pause
        ;;
      3)
        if command -v systemctl >/dev/null 2>&1; then
          systemctl status "$SERVICE_UNIT" --no-pager
        else
          echo "未检测到 systemctl，无法查看服务状态。"
        fi
        pause
        ;;
      0)
        return
        ;;
      *)
        echo "无效选择。"
        ;;
    esac
  done
}

main() {
  while true; do
    dashboard
    local choice
    if use_fzf; then
