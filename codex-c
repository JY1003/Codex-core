  if [ "$CONFIG_FORMAT" = "toml" ]; then
    [ "$(toml_exists "$path")" = "1" ]
  else
    json_exists "$path"
  fi
}

set_json_value() {
  local path="$1"
  local value="$2"
  local arr
  arr="$(path_to_jq_array "$path")"
  jq --arg v "$value" --argjson p "$arr" 'setpath($p; $v)' \
    "$CONFIG_PATH" > "$CONFIG_PATH.tmp" && mv "$CONFIG_PATH.tmp" "$CONFIG_PATH"
}

set_json_raw() {
  local path="$1"
  local raw="$2"
  local arr
  arr="$(path_to_jq_array "$path")"
  jq --argjson v "$raw" --argjson p "$arr" 'setpath($p; $v)' \
    "$CONFIG_PATH" > "$CONFIG_PATH.tmp" && mv "$CONFIG_PATH.tmp" "$CONFIG_PATH"
}

to_json_literal() {
  local input="$1"
  if echo "$input" | jq -e . >/dev/null 2>&1; then
    echo "$input"
  else
    jq -Rn --arg v "$input" '$v'
  fi
}

append_json_value() {
  local path="$1"
  local value="$2"
  local arr
  arr="$(path_to_jq_array "$path")"
  jq --arg v "$value" --argjson p "$arr" '
    def cur: (getpath($p) // "");
    def sep: (if cur == "" then "" else "\n" end);
    setpath($p; (cur + sep + $v))
  ' "$CONFIG_PATH" > "$CONFIG_PATH.tmp" && mv "$CONFIG_PATH.tmp" "$CONFIG_PATH"
}

set_config_value() {
  local path="$1"
  local value="$2"
  if [ "$CONFIG_FORMAT" = "toml" ]; then
    if [ "$path" = "$TOML_MODEL_PATH" ] || [ "$path" = ".model" ]; then
      toml_replace_model "$value"
      return $?
    fi
    if [[ "$path" == .model_providers.*.base_url ]]; then
      local provider
      provider="${path#.model_providers.}"
      provider="${provider%.base_url}"
      toml_replace_base_url "$provider" "$value"
      return $?
    fi
    echo "TOML 模式下不支持修改该字段：$path"
    return 1
  else
    set_json_value "$path" "$value"
  fi
}

append_config_value() {
  local path="$1"
  local value="$2"
  if [ "$CONFIG_FORMAT" = "toml" ]; then
    local current
    current="$(get_config_value "$path")"
    if [ -z "$current" ]; then
      set_config_value "$path" "$value"
    else
      set_config_value "$path" "${current}"$'\n'"${value}"
    fi
  else
    append_json_value "$path" "$value"
  fi
}

set_token_value() {
  local value="$1"
  if [ "$CONFIG_FORMAT" = "toml" ] && [ -f "$AUTH_PATH" ] && command -v jq >/dev/null 2>&1; then
