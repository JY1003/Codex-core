# 常见字段候选（用于自动探测）
API_URL_CANDIDATES=( '.apiUrl' '.api_url' '.endpoint' '.base_url' '.baseUrl' '.api.base_url' )
API_TOKEN_CANDIDATES=( '.api.token' '.apiToken' '.api_key' '.apiKey' '.token' )
MODEL_CANDIDATES=( '.model' '.model_name' '.modelName' '.llm.model' '.llm_model' )
PROMPT_CANDIDATES=( '.prompt' '.system_prompt' '.systemPrompt' '.system' )
MCP_CANDIDATES=( '.mcp' '.mcps' '.mcp_servers' '.mcpServers' )
SKILL_CANDIDATES=( '.skills' '.skill' '.tools' '.plugins' )

# 运行状态与版本检测
SERVICE_NAME='codex'   # 用于 pgrep 的进程名
SERVICE_UNIT='codex'   # systemd service 名称
CODEX_BIN='codex'      # 版本获取命令

# 预设配置（可自行调整）
OPENAI_API_URL='https://api.openai.com/v1'
OPENAI_MODEL='gpt-4o-mini'
ANTHROPIC_API_URL='https://api.anthropic.com'
ANTHROPIC_MODEL='claude-3-5-sonnet'

# 校验开关与参数
ENABLE_VALIDATE=1
MODEL_CHECK=1
CONNECT_TIMEOUT=3

AUTO_PATH_NOTES=()
MIGRATE_DONE=0
AUTO_MIGRATE=1
MODEL_FETCH_ERROR=""
AUTO_PATH_PROMPTED=0

term_cols() {
  local cols
  cols="$(tput cols 2>/dev/null || echo 80)"
  if ! [[ "$cols" =~ ^[0-9]+$ ]]; then
    cols=80
  fi
  if [ "$cols" -lt 60 ]; then
    cols=60
  fi
  echo "$cols"
}

print_line() {
  local cols
  cols="$(term_cols)"
  printf "%*s\n" "$cols" "" | tr ' ' '-'
}

pause() {
  read -r -p "按回车继续..." _
}

supports_utf8() {
  local v
  v="$(locale 2>/dev/null | tr '[:upper:]' '[:lower:]')"
  if echo "$v" | grep -q 'utf-8\|utf8'; then
    return 0
  fi
  v="$(printf '%s %s' "${LANG-}" "${LC_ALL-}" | tr '[:upper:]' '[:lower:]')"
  if echo "$v" | grep -q 'utf-8\|utf8'; then
    return 0
  fi
  return 1
}

init_ui() {
  if ! supports_utf8; then
    USE_COLOR=0
    USE_FZF=0
    UI_ASCII=1
  fi
  if [ -n "${NO_COLOR-}" ] || [ "${TERM-}" = "dumb" ]; then
    USE_COLOR=0
  fi
  if [ "$USE_COLOR" = "1" ] && ! tput setaf 1 >/dev/null 2>&1; then
    USE_COLOR=0
  fi
  if [ "$USE_COLOR" = "1" ]; then
    local colors
    colors="$(tput colors 2>/dev/null || echo 0)"
    if ! [[ "$colors" =~ ^[0-9]+$ ]] || [ "$colors" -lt 8 ]; then
      USE_COLOR=0
    fi
  fi
  if [ "$USE_COLOR" = "1" ] && [ -t 1 ]; then
    C_RESET=$'\033[0m'
    C_DIM=$'\033[2m'
    C_BOLD=$'\033[1m'
    C_CYAN=$'\033[36m'
    C_GREEN=$'\033[32m'
    C_YELLOW=$'\033[33m'
    C_MAGENTA=$'\033[35m'
    C_BLUE=$'\033[34m'
  else
    C_RESET=""
    C_DIM=""
    C_BOLD=""
    C_CYAN=""
    C_GREEN=""
    C_YELLOW=""
    C_MAGENTA=""
    C_BLUE=""
  fi
}

strip_ansi() {
  sed -r 's/\x1B\[[0-9;]*[mK]//g'
}

visible_len() {
  local input
  input="$(printf "%s" "$1" | strip_ansi)"
  printf "%s" "$input" | awk '{print length}'
}

pad_right() {
  local text="$1"
  local width="$2"
  local len
  if ! [[ "$width" =~ ^[0-9]+$ ]]; then
    width=0
  fi
  len="$(visible_len "$text")"
  if ! [[ "$len" =~ ^[0-9]+$ ]]; then
    len=0
  fi
  if [ "$len" -gt "$width" ]; then
    local plain
    plain="$(printf "%s" "$text" | strip_ansi)"
    printf "%.*s" "$width" "$plain"
    return
  fi
  printf "%s%*s" "$text" "$((width - len))" ""
}

truncate_text() {
  local text="$1"
  local max="$2"
  if [ -z "$max" ] || ! [[ "$max" =~ ^[0-9]+$ ]]; then
    echo "$text"
    return
  fi
  if command -v python3 >/dev/null 2>&1; then
    python3 - "$text" "$max" <<'PY'
import sys
text = sys.argv[1]
max_len = int(sys.argv[2])
if len(text) <= max_len:
    print(text)
else:
    if max_len <= 3:
        print(text[:max_len])
    else:
        print(text[:max_len-3] + "...")
PY
  else
    if [ "${#text}" -le "$max" ]; then
      echo "$text"
    else
      if [ "$max" -le 3 ]; then
        echo "${text:0:$max}"
      else
        echo "${text:0:$((max-3))}..."
      fi
    fi
  fi
}

toml_mcp_list_names() {
  sed -n 's/^\[mcp_servers\.\([^]]\+\)\]/\1/p' "$CONFIG_PATH"
}

toml_mcp_list_disabled_names() {
  sed -n 's/^\[mcp_servers_disabled\.\([^]]\+\)\]/\1/p' "$CONFIG_PATH"
}

toml_mcp_has_name() {
  local name="$1"
  grep -q "^\\[mcp_servers\\.${name}\\]$" "$CONFIG_PATH"
}

toml_mcp_has_disabled_name() {
  local name="$1"
  grep -q "^\\[mcp_servers_disabled\\.${name}\\]$" "$CONFIG_PATH"
}

toml_mcp_get_block() {
  local name="$1"
  awk -v name="$name" '
    $0 ~ "^\\[mcp_servers\\."name"\\]$" {inside=1; print; next}
    /^\[/ { if(inside){exit} }
    { if(inside) print }
  ' "$CONFIG_PATH"
}

toml_mcp_get_block_disabled() {
  local name="$1"
  awk -v name="$name" '
    $0 ~ "^\\[mcp_servers_disabled\\."name"\\]$" {inside=1; print; next}
    /^\[/ { if(inside){exit} }
    { if(inside) print }
  ' "$CONFIG_PATH"
}

toml_mcp_remove_block() {
  local name="$1"
  awk -v name="$name" '
    $0 ~ "^\\[mcp_servers\\."name"\\]$" {inside=1; next}
    /^\[/ { if(inside){inside=0} }
    { if(!inside) print }
  ' "$CONFIG_PATH" > "$CONFIG_PATH.tmp" && mv "$CONFIG_PATH.tmp" "$CONFIG_PATH"
}

toml_mcp_remove_block_disabled() {
  local name="$1"
  awk -v name="$name" '
    $0 ~ "^\\[mcp_servers_disabled\\."name"\\]$" {inside=1; next}
    /^\[/ { if(inside){inside=0} }
    { if(!inside) print }
  ' "$CONFIG_PATH" > "$CONFIG_PATH.tmp" && mv "$CONFIG_PATH.tmp" "$CONFIG_PATH"
}

toml_mcp_remove_any_block() {
  local name="$1"
  toml_mcp_remove_block "$name"
  toml_mcp_remove_block_disabled "$name"
}

toml_mcp_disable_name() {
  local name="$1"
  sed -i "s/^\\[mcp_servers\\.${name}\\]/[mcp_servers_disabled.${name}]/" "$CONFIG_PATH"
}

toml_mcp_enable_name() {
  local name="$1"
  sed -i "s/^\\[mcp_servers_disabled\\.${name}\\]/[mcp_servers.${name}]/" "$CONFIG_PATH"
}

toml_mcp_disable_all() {
  sed -i "s/^\\[mcp_servers\\./[mcp_servers_disabled./" "$CONFIG_PATH"
}

toml_mcp_enable_all() {
  sed -i "s/^\\[mcp_servers_disabled\\./[mcp_servers./" "$CONFIG_PATH"
}

toml_headers_inline_from_json() {
  local json="$1"
  if [ -z "$json" ]; then
    echo ""
    return 0
  fi
  if ! command -v python3 >/dev/null 2>&1; then
    echo ""
    return 1
  fi
  python3 - "$json" <<'PY'
import json, sys
raw = sys.argv[1]
try:
    data = json.loads(raw)
except Exception:
    sys.exit(1)
if not isinstance(data, dict):
    sys.exit(1)
parts = []
for k, v in data.items():
    if isinstance(v, str):
        v = v.replace("\\", "\\\\").replace('"', '\\"')
        parts.append(f'{k} = "{v}"')
    elif isinstance(v, bool):
        parts.append(f'{k} = {"true" if v else "false"}')
    else:
        parts.append(f'{k} = {json.dumps(v)}')
print("{ " + ", ".join(parts) + " }")
PY
}

toml_mcp_add_or_update() {
  local name="$1"
  local url="$2"
  local headers_inline="$3"
  backup_config
  toml_mcp_remove_any_block "$name"
  local escaped_url
  escaped_url="$(sed_escape "$url")"
  {
    printf "\n[mcp_servers.%s]\n" "$name"
    printf "url = \"%s\"\n" "$escaped_url"
    if [ -n "$headers_inline" ]; then
      printf "headers = %s\n" "$headers_inline"
    fi
  } >> "$CONFIG_PATH"
}

toml_mcp_add_raw_block() {
  local name="$1"
  local block="$2"
  backup_config
  toml_mcp_remove_any_block "$name"
  printf "\n%s\n" "$block" >> "$CONFIG_PATH"
}

toml_mcp_replace_block() {
  local old_name="$1"
  local new_name="$2"
  local block="$3"
  backup_config
  toml_mcp_remove_any_block "$old_name"
  if [ "$new_name" != "$old_name" ]; then
    toml_mcp_remove_any_block "$new_name"
  fi
  printf "\n%s\n" "$block" >> "$CONFIG_PATH"
}

toml_mcp_count() {
  require_python || { echo "0"; return; }
  python3 - "$CONFIG_PATH" <<'PY'
