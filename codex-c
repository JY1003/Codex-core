extract_model_ids() {
  local file="$1"
  jq -r '
    def normalize:
      if type == "string" then .
      elif type == "object" then (.id // .name // .model // empty)
      else empty end;
    if has("data") then (.data[]? | normalize)
    elif has("models") then (.models[]? | normalize)
    elif has("model_list") then (.model_list[]? | normalize)
    else empty end
  ' "$file" 2>/dev/null
}

clean_value() {
  local value="$1"
  printf '%s' "$value" | tr -d $'\"\' \r\n\t'
}

get_auth_mode() {
  if [ -f "$AUTH_PATH" ] && command -v jq >/dev/null 2>&1; then
    jq -r '.auth_mode // empty' "$AUTH_PATH" 2>/dev/null
  fi
}

curl_openai_models() {
  local endpoint="$1"
  local token="$2"
  local tmp="$3"
  local clean_endpoint clean_token auth_mode header code
  clean_endpoint="$(clean_value "$endpoint")"
  clean_token="$(clean_value "$token")"
  if [ -z "$clean_token" ]; then
    code="$(command curl -q -sS -o "$tmp" -w "%{http_code}" "$clean_endpoint" || true)"
    echo "$code"
    return 0
  fi
  auth_mode="$(get_auth_mode)"
  if [ "$auth_mode" = "apikey" ]; then
    header="x-api-key: $clean_token"
  else
    header="Authorization: Bearer $clean_token"
  fi
  code="$(command curl -q -sS -X GET \
    -H "$header" \
    -o "$tmp" -w "%{http_code}" "$clean_endpoint" || true)"
  echo "$code"
}

fetch_model_list() {
  MODEL_FETCH_ERROR=""
  local api_url token provider
  local token_source="config"
  api_url="${1:-}"
  token="${2:-}"
  provider="${3:-}"
  if [ -n "${2:-}" ]; then
    token_source="param"
  fi
  if [ -z "$api_url" ]; then
    api_url="$(get_config_value "$API_URL_PATH")"
  fi
  if [ -z "$token" ]; then
    token="$(get_config_value "$API_TOKEN_PATH")"
  fi
  if [ -n "$api_url" ]; then
    api_url="$(clean_value "$api_url")"
  fi
  if [ -z "$provider" ]; then
    provider="$(detect_provider "$api_url")"
  fi
  if [ -z "$token" ] && [ -f "$AUTH_PATH" ] && command -v jq >/dev/null 2>&1; then
    if [ "$provider" = "anthropic" ]; then
      token="$(jq -r '.ANTHROPIC_API_KEY // empty' "$AUTH_PATH" 2>/dev/null)"
      token_source="auth:ANTHROPIC_API_KEY"
    else
      token="$(jq -r '.OPENAI_API_KEY // empty' "$AUTH_PATH" 2>/dev/null)"
      token_source="auth:OPENAI_API_KEY"
    fi
  fi
  if [ -n "$token" ]; then
    token="$(clean_value "$token")"
  fi
  if [ -z "$token" ]; then
    :
    return 1
  fi
  if [ -z "$provider" ]; then
    provider="$(detect_provider "$api_url")"
  fi
  if [ -z "$api_url" ]; then
    MODEL_FETCH_ERROR="未设置 API 地址"
    return 1
  fi
  if ! command -v curl >/dev/null 2>&1; then
    MODEL_FETCH_ERROR="未检测到 curl"
    return 1
  fi
  if ! command -v jq >/dev/null 2>&1; then
    MODEL_FETCH_ERROR="未检测到 jq"
    return 1
  fi
  local base endpoint tmp code
  base="$(normalize_api_url "$api_url")"
  if [ "$provider" = "openai" ]; then
    if [ -z "$token" ]; then
      MODEL_FETCH_ERROR="未读取到 Token"
      return 1
    fi
    endpoint="${base}/models"
    tmp="$(mktemp)"
    code="$(curl_openai_models "$endpoint" "$token" "$tmp")"
    if [ "$code" != "200" ]; then
      if [ "$code" = "000" ]; then
        MODEL_FETCH_ERROR="无法连接到 API"
      else
        MODEL_FETCH_ERROR="模型列表请求失败 (HTTP $code)"
      fi
      rm -f "$tmp"
      return 1
    fi
    local models
    models="$(extract_model_ids "$tmp")"
    rm -f "$tmp"
    if [ -z "$models" ]; then
      MODEL_FETCH_ERROR="模型列表为空或接口返回格式不兼容"
      return 1
    fi
    printf '%s\n' "$models"
    return 0
  fi
  if [ "$provider" = "anthropic" ]; then
    if [[ "$base" == */v1 ]]; then
      endpoint="${base}/models"
    else
      endpoint="${base}/v1/models"
    fi
    tmp="$(mktemp)"
    if [ -n "$token" ]; then
      code="$(curl -sS -H "x-api-key: $token" -H "anthropic-version: 2023-06-01" -o "$tmp" -w "%{http_code}" "$endpoint" || true)"
    else
      code="$(curl -sS -H "anthropic-version: 2023-06-01" -o "$tmp" -w "%{http_code}" "$endpoint" || true)"
    fi
    if [ "$code" != "200" ]; then
      if [ "$code" = "000" ]; then
        MODEL_FETCH_ERROR="无法连接到 API"
      else
        MODEL_FETCH_ERROR="模型列表请求失败 (HTTP $code)"
      fi
      rm -f "$tmp"
      return 1
    fi
    local models
    models="$(extract_model_ids "$tmp")"
    rm -f "$tmp"
    if [ -z "$models" ]; then
      MODEL_FETCH_ERROR="模型列表为空或接口返回格式不兼容"
      return 1
    fi
    printf '%s\n' "$models"
    return 0
  fi
  # 兼容 OpenAI 风格的自定义服务
  if [ "$CONFIG_FORMAT" = "toml" ]; then
    local provider_name requires_auth requires_auth_raw
    provider_name="$(get_toml_value "$TOML_PROVIDER_PATH")"
    if [ -n "$provider_name" ]; then
      requires_auth_raw="$(get_toml_value ".model_providers.${provider_name}.requires_openai_auth")"
      requires_auth="$(printf '%s' "$requires_auth_raw" | tr '[:upper:]' '[:lower:]')"
    fi
    endpoint="${base}/models"
    if { [ "$requires_auth" = "true" ] || [ "$requires_auth" = "1" ]; } && [ -z "$token" ]; then
      MODEL_FETCH_ERROR="该服务要求 Token"
      return 1
    fi
    tmp="$(mktemp)"
    if [ "$requires_auth" = "true" ] || [ "$requires_auth" = "1" ]; then
      code="$(curl_openai_models "$endpoint" "$token" "$tmp")"
    else
      code="$(curl -sS -o "$tmp" -w "%{http_code}" "$endpoint" || true)"
    fi
    if [ "$code" != "200" ]; then
      if [ "$code" = "000" ]; then
        MODEL_FETCH_ERROR="无法连接到 API"
      else
        MODEL_FETCH_ERROR="模型列表请求失败 (HTTP $code)"
      fi
      rm -f "$tmp"
      return 1
    fi
    local models
    models="$(extract_model_ids "$tmp")"
    rm -f "$tmp"
    if [ -z "$models" ]; then
      MODEL_FETCH_ERROR="模型列表为空或接口返回格式不兼容"
      return 1
    fi
    printf '%s\n' "$models"
    return 0
  fi
  endpoint="${base}/models"
  tmp="$(mktemp)"
  code="$(curl_openai_models "$endpoint" "$token" "$tmp")"
  if [ "$code" != "200" ]; then
    if [ "$code" = "000" ]; then
      MODEL_FETCH_ERROR="无法连接到 API"
    else
      MODEL_FETCH_ERROR="模型列表请求失败 (HTTP $code)"
    fi
    rm -f "$tmp"
    return 1
  fi
  local models
  models="$(extract_model_ids "$tmp")"
  rm -f "$tmp"
  if [ -z "$models" ]; then
    MODEL_FETCH_ERROR="模型列表为空或接口返回格式不兼容"
    return 1
  fi
  printf '%s\n' "$models"
  return 0
}

fetch_models_into() {
  local dest="$1"
