  fi
  read -r -p "检测到配置中有 Skill 数据，是否导出到 ${SKILLS_DIR}？[y/N] " ans
  if [[ "$ans" =~ ^[Yy]$ ]]; then
    python3 - "$CONFIG_PATH" "$SKILLS_DIR" "$SKILL_PATH" <<'PY'
import sys, json, os
cfg_path, out_dir, path = sys.argv[1], sys.argv[2], sys.argv[3]
with open(cfg_path, 'r', encoding='utf-8') as f:
    data = json.load(f)
cur = data
for p in path.lstrip('.').split('.'):
    if not p:
        continue
    cur = cur.get(p)
    if cur is None:
        sys.exit(0)
def write_item(name, obj):
    dir_path = os.path.join(out_dir, name)
    os.makedirs(dir_path, exist_ok=True)
    file_path = os.path.join(dir_path, 'SKILL.md')
