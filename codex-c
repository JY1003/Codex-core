ensure_collection_kind() {
  local label="$1"
  local path="$2"
  if [ "$CONFIG_FORMAT" = "toml" ]; then
    echo "$label TOML 模式下暂不支持新增/删除，请使用 Vim 编辑。"
    return 1
  fi
  local kind
  kind="$(json_type "$path")"
  if [ "$kind" = "null" ]; then
    echo "$label 配置不存在，需要先初始化类型。"
    echo "1. 数组"
    echo "2. 对象"
    echo "0. 返回"
    read -r -p "请选择（留空返回）: " init_choice
    if [ -z "$init_choice" ]; then
      return 1
    fi
    case "$init_choice" in
      1)
        backup_config
        set_json_raw "$path" "[]"
        echo "已初始化为空数组。"
        ;;
      2)
        backup_config
        set_json_raw "$path" "{}"
        echo "已初始化为空对象。"
        ;;
      0)
        return 1
        ;;
      *)
        echo "无效选择。"
        return 1
        ;;
    esac
    kind="$(json_type "$path")"
  fi
  if [ "$kind" != "array" ] && [ "$kind" != "object" ]; then
    echo "$label 当前类型为 $kind，无法执行新增/删除，请用 Vim 手动调整。"
    return 1
  fi
  echo "$kind"
}

collection_add() {
  local label="$1"
  local path="$2"
  local kind
  kind="$(ensure_collection_kind "$label" "$path")" || return 1

  if [ "$kind" = "array" ]; then
    read -r -p "请输入要新增的条目（支持 JSON，普通文本将作为字符串，留空取消）： " item
    if [ -z "$item" ]; then
      echo "未输入，已取消。"
      return 1
    fi
    local json_item
    json_item="$(to_json_literal "$item")"
    backup_config
    local arr
    arr="$(path_to_jq_array "$path")"
    jq --argjson item "$json_item" --argjson p "$arr" \
      'setpath($p; (getpath($p)//[]) + [$item])' \
      "$CONFIG_PATH" > "$CONFIG_PATH.tmp" && mv "$CONFIG_PATH.tmp" "$CONFIG_PATH"
    echo "已新增条目。"
  else
    read -r -p "请输入新增项的 key（留空取消）： " key
    if [ -z "$key" ]; then
      echo "未输入，已取消。"
      return 1
    fi
    read -r -p "请输入新增项的 value（支持 JSON，普通文本将作为字符串，留空取消）： " value
    if [ -z "$value" ]; then
      echo "未输入，已取消。"
      return 1
    fi
    local json_value
    json_value="$(to_json_literal "$value")"
    backup_config
    local arr
    arr="$(path_to_jq_array "$path")"
    jq --arg k "$key" --argjson v "$json_value" --argjson p "$arr" \
      'setpath($p; (getpath($p)//{}) | .[$k] = $v)' \
      "$CONFIG_PATH" > "$CONFIG_PATH.tmp" && mv "$CONFIG_PATH.tmp" "$CONFIG_PATH"
    echo "已新增条目。"
  fi
}

collection_remove() {
  local label="$1"
  local path="$2"
  local kind
  kind="$(ensure_collection_kind "$label" "$path")" || return 1

  if [ "$kind" = "array" ]; then
    echo "当前条目列表（索引: 内容）："
    jq -r "$path | to_entries[] | \"\\(.key): \\(.value|@json)\"" "$CONFIG_PATH" 2>/dev/null
    read -r -p "请输入要删除的索引（留空取消）: " idx
    if [ -z "$idx" ]; then
      echo "未输入，已取消。"
      return 1
    fi
    if ! [[ "$idx" =~ ^[0-9]+$ ]]; then
      echo "索引必须是数字。"
      return 1
    fi
    backup_config
    local arr
    arr="$(path_to_jq_array "$path")"
    jq --argjson i "$idx" --argjson p "$arr" \
      'setpath($p; (getpath($p)//[]) | del(.[$i]))' \
      "$CONFIG_PATH" > "$CONFIG_PATH.tmp" && mv "$CONFIG_PATH.tmp" "$CONFIG_PATH"
    echo "已删除条目。"
  else
    echo "当前条目列表（key: value）："
    jq -r "$path | to_entries[] | \"\\(.key): \\(.value|@json)\"" "$CONFIG_PATH" 2>/dev/null
    read -r -p "请输入要删除的 key（留空取消）: " key
    if [ -z "$key" ]; then
      echo "未输入，已取消。"
      return 1
    fi
    backup_config
    local arr
    arr="$(path_to_jq_array "$path")"
    jq --arg k "$key" --argjson p "$arr" \
      'setpath($p; (getpath($p)//{}) | del(.[$k]))' \
      "$CONFIG_PATH" > "$CONFIG_PATH.tmp" && mv "$CONFIG_PATH.tmp" "$CONFIG_PATH"
    echo "已删除条目。"
  fi
}

