ui_status_box() {
  local cols box_width inner_width max_len
  cols="$(term_cols)"
  box_width=50
  if [ "$cols" -lt "$box_width" ]; then
    box_width="$cols"
  fi
  if [ "$box_width" -lt 30 ]; then
    box_width=30
  fi
  inner_width=$((box_width - 1))
  max_len=$((inner_width - 2))

  local hline
  hline="$(printf "%*s" "$inner_width" "" | tr ' ' '-')"
  if [ -n "$C_DIM" ]; then
    printf "%s+%s%s\n" "$C_DIM" "$hline" "$C_RESET"
  else
    printf "+%s\n" "$hline"
  fi
  while [ "$#" -gt 0 ]; do
    local line
    line="$(truncate_text "$1" "$max_len")"
    if [ -n "$C_DIM" ]; then
      printf "%s|%s %s\n" "$C_DIM" "$C_RESET" "$line"
    else
      printf "| %s\n" "$line"
    fi
    shift
  done
  if [ -n "$C_DIM" ]; then
    printf "%s+%s%s\n" "$C_DIM" "$hline" "$C_RESET"
  else
    printf "+%s\n" "$hline"
  fi
}

use_fzf() {
  false
}

menu_choose() {
  local title="$1"
  shift
  local items=("$@")
  local idx_map=()
  if use_fzf; then
    local list=()
    local i=1
    local item
    for item in "${items[@]}"; do
      local idx="$i"
      if [[ "$item" =~ ^(返回|退出) ]]; then
        idx=0
      fi
      idx_map+=( "$idx" )
      list+=( "$(printf '%s%2d%s %s' "$C_MAGENTA" "$idx" "$C_RESET" "$item")" )
      i=$((i + 1))
    done
    local selection
    local fzf_opts=(--prompt "$title > " --height 40% --border --reverse --no-multi --no-unicode)
    if [ "$USE_COLOR" = "1" ]; then
      fzf_opts+=(--ansi)
    fi
    if [ "$UI_ASCII" = "1" ]; then
      fzf_opts+=(--no-unicode)
    fi
    selection="$(printf '%s\n' "${list[@]}" | fzf "${fzf_opts[@]}")"
    if [ -z "$selection" ]; then
      echo ""
      return 1
    fi
    if [[ "$selection" =~ ([0-9]+) ]]; then
      echo "${BASH_REMATCH[1]}"
      return 0
    fi
    return 1
  else
    printf "%s%s%s\n" "$C_BOLD$C_BLUE" "$title" "$C_RESET" >&2
    local i=1
    local item
    for item in "${items[@]}"; do
      local idx="$i"
      if [[ "$item" =~ ^(返回|退出) ]]; then
        idx=0
      fi
      idx_map+=( "$idx" )
      if [ -n "$C_CYAN" ]; then
        printf "[ %s%d%s ] %s\n" "$C_BOLD$C_MAGENTA" "$idx" "$C_RESET" "$item" >&2
      else
        printf "[ %d ] %s\n" "$idx" "$item" >&2
      fi
      i=$((i + 1))
    done
    read -r -p "codex-core $(prompt_symbol) 请输入对应数字选择: " choice
    echo "$choice"
  fi
}

require_jq() {
  if ! command -v jq >/dev/null 2>&1; then
    echo "未检测到 jq，无法读取或修改 JSON 配置。请先安装 jq。"
    return 1
  fi
  return 0
}

require_python() {
  if ! command -v python3 >/dev/null 2>&1; then
    echo "未检测到 python3，无法解析 TOML 配置。请先安装 python3。"
    return 1
  fi
  return 0
}

auto_detect_config_path() {
  if [ "$CONFIG_PATH" != "$DEFAULT_CONFIG_PATH" ]; then
    return 0
  fi
  if [ -f "/root/.codex/config.toml" ]; then
    CONFIG_PATH="/root/.codex/config.toml"
  elif [ -f "/root/.codex/config.json" ]; then
    CONFIG_PATH="/root/.codex/config.json"
  else
    local candidates=()
    local cand
    candidates+=( "$HOME/.codex/config.toml" "$HOME/.codex/config.json" )
    for cand in /home/*/.codex/config.toml /home/*/.codex/config.json; do
      candidates+=( "$cand" )
    done
    for cand in "${candidates[@]}"; do
      if [ -f "$cand" ]; then
        CONFIG_PATH="$cand"
        return 0
      fi
    done
    if [ "$AUTO_PATH_PROMPTED" = "0" ]; then
      AUTO_PATH_PROMPTED=1
      echo "未自动找到 codex 配置目录。"
      read -r -p "请输入 .codex 目录路径（留空跳过）： " user_dir
      if [ -n "$user_dir" ]; then
        if [ -f "$user_dir/config.toml" ]; then
          CONFIG_PATH="$user_dir/config.toml"
        elif [ -f "$user_dir/config.json" ]; then
          CONFIG_PATH="$user_dir/config.json"
        else
          echo "未在该目录找到 config.toml 或 config.json。"
        fi
      fi
    fi
  fi
}

sync_codex_dirs() {
  if [ -z "$CODEX_DIR" ]; then
    if [ -n "$CONFIG_PATH" ] && [ -e "$CONFIG_PATH" ]; then
      CODEX_DIR="$(dirname "$CONFIG_PATH")"
    elif [ -d "/root/.codex" ]; then
      CODEX_DIR="/root/.codex"
    else
      CODEX_DIR="$(pwd)"
    fi
  fi

  if [ -z "$PROMPTS_DIR" ]; then
    PROMPTS_DIR="$CODEX_DIR/prompts"
  fi
  if [ -z "$SKILLS_DIR" ]; then
    SKILLS_DIR="$CODEX_DIR/skills"
  fi
  if [ -z "$MCP_DIR" ]; then
    MCP_DIR="$CODEX_DIR/mcp"
  fi
  if [ -z "$API_PROFILES_PATH" ]; then
    API_PROFILES_PATH="$CODEX_DIR/api_profiles.json"
  fi
  if [ -z "$TRASH_DIR" ]; then
    TRASH_DIR="$CODEX_DIR/trash"
  fi
}

ensure_dir() {
  local dir="$1"
  local label="$2"
  if [ -d "$dir" ]; then
    return 0
  fi
  echo "$label 目录不存在：$dir"
  read -r -p "是否创建？[y/N] " ans
  if [[ "$ans" =~ ^[Yy]$ ]]; then
    mkdir -p "$dir" || {
      echo "创建失败：$dir"
      return 1
    }
    return 0
  fi
  return 1
}

trash_move() {
  local src="$1"
  local label="$2"
  sync_codex_dirs
  ensure_dir "$TRASH_DIR" "Trash" || return 1
  if [ ! -e "$src" ]; then
    echo "未找到：$src"
    return 1
  fi
  local base ts dest
  base="$(basename "$src")"
  ts="$(date +%Y%m%d_%H%M%S)"
  dest="$TRASH_DIR/${label}-${base}-${ts}"
  mv "$src" "$dest" && echo "已移动到回收站：$dest"
}

normalize_name() {
  local name="$1"
  name="${name//\\/}"
  name="${name//\//}"
  name="${name// /-}"
  echo "$name"
}

prompt_path_from_name() {
  local name
  name="$(normalize_name "$1")"
  if [[ "$name" != *.md ]]; then
    name="${name}.md"
  fi
  echo "$PROMPTS_DIR/$name"
}

skill_dir_from_name() {
  local name
  name="$(normalize_name "$1")"
  echo "$SKILLS_DIR/$name"
}

mcp_path_from_name() {
  local name
  name="$(normalize_name "$1")"
  if [[ "$name" != *"$MCP_FILE_EXT" ]]; then
    name="${name}${MCP_FILE_EXT}"
  fi
  echo "$MCP_DIR/$name"
}

detect_config_format() {
  if [ "$CONFIG_FORMAT" = "json" ] || [ "$CONFIG_FORMAT" = "toml" ]; then
    return 0
  fi
  case "$CONFIG_PATH" in
    *.toml) CONFIG_FORMAT="toml" ;;
    *.json) CONFIG_FORMAT="json" ;;
    *)
      if command -v jq >/dev/null 2>&1 && jq empty "$CONFIG_PATH" >/dev/null 2>&1; then
        CONFIG_FORMAT="json"
      elif command -v python3 >/dev/null 2>&1; then
        if python3 - <<'PY' "$CONFIG_PATH" >/dev/null 2>&1
import sys, tomllib
with open(sys.argv[1], 'rb') as f:
    tomllib.load(f)
PY
        then
          CONFIG_FORMAT="toml"
        else
          CONFIG_FORMAT="json"
        fi
      else
        CONFIG_FORMAT="json"
      fi
      ;;
  esac
}

restore_backup() {
  if [ -f "$CONFIG_PATH.bak" ]; then
    cp -f "$CONFIG_PATH.bak" "$CONFIG_PATH"
    echo "校验失败，已自动回滚到 $CONFIG_PATH.bak"
  else
    echo "校验失败，但未找到备份文件，无法回滚。"
  fi
  if [ -f "$AUTH_PATH.bak" ]; then
    cp -f "$AUTH_PATH.bak" "$AUTH_PATH"
    echo "已回滚鉴权文件到 $AUTH_PATH.bak"
  fi
}

validate_or_rollback() {
  if ! validate_api_model; then
    restore_backup
    return 1
  fi
  return 0
}

ensure_config() {
  auto_detect_config_path
  detect_config_format
  if [ ! -f "$CONFIG_PATH" ]; then
    echo "配置文件不存在：$CONFIG_PATH"
    read -r -p "是否创建空配置文件 {} ？[y/N] " ans
    if [[ "$ans" =~ ^[Yy]$ ]]; then
      if [ "$CONFIG_FORMAT" = "toml" ]; then
        printf '' > "$CONFIG_PATH"
      else
        printf '{}' > "$CONFIG_PATH"
      fi
      echo "已创建空配置文件。"
    else
      return 1
    fi
  fi
  if [ "$CONFIG_FORMAT" = "json" ]; then
    if ! jq empty "$CONFIG_PATH" >/dev/null 2>&1; then
      echo "配置文件不是有效 JSON：$CONFIG_PATH"
      return 1
    fi
  else
    require_python || return 1
    if ! python3 - <<'PY' "$CONFIG_PATH" >/dev/null 2>&1
import sys, tomllib
with open(sys.argv[1], 'rb') as f:
    tomllib.load(f)
PY
    then
      echo "配置文件不是有效 TOML：$CONFIG_PATH"
      return 1
    fi
  fi
  return 0
}

backup_config() {
  if [ -f "$CONFIG_PATH" ]; then
    cp -f "$CONFIG_PATH" "$CONFIG_PATH.bak"
  fi
}

backup_auth() {
  if [ -f "$AUTH_PATH" ]; then
    cp -f "$AUTH_PATH" "$AUTH_PATH.bak"
  fi
}

sed_escape() {
  printf '%s' "$1" | sed -e 's/[\\/&"]/\\&/g'
}

toml_replace_model() {
  local value="$1"
  local escaped
  escaped="$(sed_escape "$value")"
  if grep -q '^model = ' "$CONFIG_PATH"; then
    sed -i "s/^model = .*/model = \"${escaped}\"/" "$CONFIG_PATH"
    return 0
  fi
  echo "未找到 model 行，无法修改。"
  return 1
}

toml_replace_base_url() {
  local provider="$1"
  local value="$2"
  local escaped
  escaped="$(sed_escape "$value")"
  if grep -q "^\\[model_providers\\.${provider}\\]" "$CONFIG_PATH"; then
    sed -i "/^\\[model_providers\\.${provider}\\]/,/^\\[/{s|^base_url = .*|base_url = \"${escaped}\"|}" "$CONFIG_PATH"
    return 0
  fi
  if grep -q '^base_url = ' "$CONFIG_PATH"; then
    sed -i "s|^base_url = .*|base_url = \"${escaped}\"|" "$CONFIG_PATH"
    return 0
  fi
  echo "未找到 base_url 行，无法修改。"
  return 1
}

path_to_jq_array() {
  local path="$1"
  local stripped="${path#.}"
  IFS='.' read -r -a parts <<< "$stripped"
  local json='['
  local part
  for part in "${parts[@]}"; do
    if [ -n "$part" ]; then
      json+="\"$part\","
    fi
  done
  json="${json%,}]"
  echo "$json"
}

get_json_value() {
  local path="$1"
  jq -r "$path // empty" "$CONFIG_PATH" 2>/dev/null
}

json_exists() {
  local path="$1"
  jq -e "$path != null" "$CONFIG_PATH" >/dev/null 2>&1
}

get_toml_value() {
  local path="$1"
  require_python || return 1
  python3 - "$CONFIG_PATH" "$path" <<'PY'
import sys, json, tomllib
cfg_path = sys.argv[1]
path = sys.argv[2].lstrip('.')
parts = [p for p in path.split('.') if p]
with open(cfg_path, 'rb') as f:
    data = tomllib.load(f)
cur = data
for p in parts:
    if isinstance(cur, dict) and p in cur:
        cur = cur[p]
    else:
        print("")
        sys.exit(0)
if cur is None:
    print("")
elif isinstance(cur, (dict, list)):
    print(json.dumps(cur, ensure_ascii=False))
else:
    print(cur)
PY
}

toml_exists() {
  local path="$1"
  require_python || return 1
  python3 - "$CONFIG_PATH" "$path" <<'PY'
import sys, tomllib
cfg_path = sys.argv[1]
path = sys.argv[2].lstrip('.')
parts = [p for p in path.split('.') if p]
with open(cfg_path, 'rb') as f:
    data = tomllib.load(f)
cur = data
for p in parts:
    if isinstance(cur, dict) and p in cur:
        cur = cur[p]
    else:
        print("0")
        sys.exit(0)
print("1")
PY
}

toml_escape() {
  local value="$1"
  python3 - "$value" <<'PY'
import sys
v = sys.argv[1]
if "\n" in v:
    v = v.replace('"""', '\\"""')
    print('"""' + v + '"""')
else:
    v = v.replace('\\', '\\\\').replace('"', '\\"')
    print('"' + v + '"')
PY
}

toml_set_value() {
  local path="$1"
  local value="$2"
  require_python || return 1
  local keypath="${path#.}"
  local section="${keypath%.*}"
  local key="${keypath##*.}"
  local literal
  literal="$(toml_escape "$value")"
  python3 - "$CONFIG_PATH" "$section" "$key" "$literal" <<'PY'
import sys, re
cfg_path, section, key, literal = sys.argv[1], sys.argv[2], sys.argv[3], sys.argv[4]
with open(cfg_path, 'r', encoding='utf-8') as f:
    lines = f.readlines()

out = []
current = None
section_found = False
key_written = False

def is_section(line):
    m = re.match(r'^\s*\[(.+?)\]\s*$', line)
    return m.group(1) if m else None

for line in lines:
    sec = is_section(line)
    if sec is not None:
        if section and sec == section:
            section_found = True
        current = sec
        out.append(line)
        continue

    if (not section and current is None) or (section and current == section):
        if re.match(r'^\s*' + re.escape(key) + r'\s*=', line):
            out.append(f"{key} = {literal}\n")
            key_written = True
        else:
            out.append(line)
    else:
        out.append(line)

if not key_written:
    if section:
        if not section_found:
            if out and not out[-1].endswith("\n"):
                out[-1] += "\n"
            out.append(f"\n[{section}]\n")
        inserted = False
        new_out = []
        current = None
        for line in out:
            sec = is_section(line)
            if sec is not None:
                if current == section and not inserted:
                    new_out.append(f"{key} = {literal}\n")
                    inserted = True
                current = sec
                new_out.append(line)
            else:
                new_out.append(line)
        if current == section and not inserted:
            new_out.append(f"{key} = {literal}\n")
            inserted = True
        out = new_out
    else:
        if out and not out[-1].endswith("\n"):
            out[-1] += "\n"
        out.append(f"{key} = {literal}\n")

with open(cfg_path, 'w', encoding='utf-8') as f:
    f.writelines(out)
PY
}

get_config_value() {
