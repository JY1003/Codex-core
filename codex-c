select_from_list() {
  local prompt="$1"
  shift
  local items=("$@")
  if [ "${#items[@]}" -eq 0 ]; then
    return 1
  fi
  local i=1
  for item in "${items[@]}"; do
    echo "${i}. ${item}" >&2
    i=$((i + 1))
  done
  read -r -p "$prompt" idx
  if ! [[ "$idx" =~ ^[0-9]+$ ]]; then
    return 1
  fi
  if [ "$idx" -lt 1 ] || [ "$idx" -gt "${#items[@]}" ]; then
    return 1
  fi
  echo "${items[$((idx - 1))]}"
}

select_model_or_name() {
  local prompt="$1"
  shift
  local items=("$@")
  local i=1
  for item in "${items[@]}"; do
    echo "${i}. ${item}" >&2
    i=$((i + 1))
  done
  local input
  read -r -p "$prompt" input
  if [[ "$input" =~ ^[0-9]+$ ]]; then
    if [ "$input" -ge 1 ] && [ "$input" -le "${#items[@]}" ]; then
      echo "${items[$((input - 1))]}"
      return 0
    fi
    return 1
  fi
  echo "$input"
}

filter_codex_models() {
  local models=("$@")
  local gpt_codex=()
  local codex=()
  local m
  for m in "${models[@]}"; do
    if [[ "$m" == *codex* ]] || [[ "$m" == *Codex* ]]; then
      codex+=( "$m" )
      if [[ "$m" == *gpt* ]] || [[ "$m" == *GPT* ]]; then
        gpt_codex+=( "$m" )
      fi
    fi
  done
  if [ "${#gpt_codex[@]}" -gt 0 ]; then
    printf '%s\n' "${gpt_codex[@]}"
  elif [ "${#codex[@]}" -gt 0 ]; then
    printf '%s\n' "${codex[@]}"
  else
    printf '%s\n' "${models[@]}"
  fi
}

